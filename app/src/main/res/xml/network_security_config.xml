<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block cleartext (HTTP) traffic by default -->
    <base-config cleartextTrafficPermitted="false" />

    <!-- Allow cleartext only for local emulator in debug builds -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>

    <!-- Allow cleartext to Android emulator loopback for debug API -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
